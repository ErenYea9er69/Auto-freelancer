{
  "name": "goalpilot-extension",
  "displayName": "GOALpilot",
  "description": "Autonomous AI Coding Agent for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning"
  ],
  "activationEvents": [
    "onView:goalpilot-sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "GOALpilot",
      "properties": {
        "goalpilot.longcatApiKey": {
          "type": "string",
          "default": "",
          "description": "Your LongCat AI API Key",
          "scope": "application"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "goalpilot-sidebar-container",
          "title": "GOALpilot"
        }
      ]
    },
    "views": {
      "goalpilot-sidebar-container": [
        {
          "type": "webview",
          "id": "goalpilot-sidebar",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "goalpilot.start",
        "title": "Start GOALpilot"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^18.x",
    "typescript": "^5.x",
    "esbuild": "^0.20.x"
  }
}
